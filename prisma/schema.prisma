generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @db.Timestamptz
  image         String?
  password      String?
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now()) @db.Timestamptz
  accounts      Account[]
  sessions      Session[]
  teacher       Teacher?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
}

model Teacher {
  id        String    @id @default(cuid())
  userId    String    @unique
  timezone  String    @default("UTC")
  createdAt DateTime  @default(now()) @db.Timestamptz
  lessons   Lesson[]
  students  Student[]
  pieces    Piece[]
  payments  PaymentMonth[]
  paymentTransactions PaymentTransaction[]
  user      User      @relation(fields: [userId], references: [id])
}

model Student {
  id         String          @id @default(cuid())
  teacherId  String
  name       String
  avatar     String?
  notes      String?
  lessonRate Int             @default(0)
  createdAt  DateTime        @default(now()) @db.Timestamptz
  lessons    Lesson[]
  teacher    Teacher         @relation(fields: [teacherId], references: [id])
  reports    MonthlyReport[]
  payments   PaymentMonth[]
  paymentTransactions PaymentTransaction[]
}

model Piece {
  id          String   @id @default(cuid())
  teacherId   String
  title       String
  description String?
  level       String?
  difficulty  Int?
  createdAt   DateTime @default(now()) @db.Timestamptz
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  lessons     Lesson[]
}

model Lesson {
  id           String       @id @default(cuid())
  studentId    String
  teacherId    String
  date         DateTime     @db.Timestamptz
  duration     Int
  status       LessonStatus @default(PENDING)
  actualMin    Int?
  cancelReason String?
  note         String?
  pieceId      String?
  createdAt    DateTime     @default(now()) @db.Timestamptz
  piece        Piece?       @relation(fields: [pieceId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  teacher      Teacher      @relation(fields: [teacherId], references: [id])

  @@index([teacherId, date])
  @@index([studentId, date])
}

enum LessonStatus {
  PENDING
  COMPLETE
  CANCELLED
  MAKEUP
}

model MonthlyReport {
  id            String  @id @default(cuid())
  studentId     String
  month         Int
  year          Int
  summary       String?
  comments      String?
  nextMonthPlan String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month, year])
}

model PaymentMonth {
  id             String   @id @default(cuid())
  studentId      String
  teacherId      String
  month          Int
  year           Int
  expectedAmount Int
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  student      Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      Teacher               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@unique([studentId, month, year])
  @@index([teacherId, month, year])
  @@index([studentId, year])
}

model PaymentTransaction {
  id             String   @id @default(cuid())
  paymentMonthId String
  studentId      String
  teacherId      String
  amount         Int
  method         String?
  note           String?
  date           DateTime @default(now()) @db.Timestamptz
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  paymentMonth PaymentMonth @relation(fields: [paymentMonthId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, date])
  @@index([studentId, date])
  @@index([paymentMonthId])
}
